{
  "name": "threadwise",
  "version": "0.1.0",
  "description": "ThreadWise is a local-first AI Chrome extension for finding high-value Reddit threads.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohansella/ThreadWise.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "manifest": {
    "name": "ThreadWise",
    "short_name": "ThreadWise",
    "version": "0.1.0",
    "description": "A local-first AI analyst for high-value Reddit threads.",
    "manifest_version": 3,
    "permissions": [
      "storage",
      "alarms",
      "notifications"
    ],
    "host_permissions": [
      "https://www.reddit.com/*",
      "https://old.reddit.com/*",
      "https://*.reddit.com/*"
    ],
    "optional_host_permissions": [
      "https://*/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "bugs": {
    "url": "https://github.com/mohansella/ThreadWise/issues"
  },
  "homepage": "https://github.com/mohansella/ThreadWise#readme",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/google": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "@ai-sdk/openai-compatible": "^2.0.47",
    "ai": "^6.0.188",
    "clsx": "^2.1.1",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "plasmo": "^0.90.5",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  }
}
